OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen3.5:latest
OLLAMA_LOGIC_MODEL=qwen2.5-coder:7b
OLLAMA_VISION_MODEL=gemma3:latest
OLLAMA_KEEP_ALIVE=10m

OPENAI_API_KEY=your_api_key_here
OPENAI_TEXT_MODEL=gpt-5.2-chat-latest
OPENAI_IMAGE_MODEL=gpt-5

# Free local image generation. Leave as local-collage for the built-in zero-cost renderer.
# Use localai for http://127.0.0.1:8080/v1/images/generations.
# Use comfyui for a local ComfyUI workflow exported in API format.
IMAGE_PROVIDER=local-collage
LOCALAI_BASE_URL=http://127.0.0.1:8080
LOCALAI_IMAGE_MODEL=
LOCALAI_IMAGE_SIZE=1024x1024
LOCALAI_IMAGE_STEPS=25
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_PATH=
COMFYUI_TIMEOUT_MS=180000
